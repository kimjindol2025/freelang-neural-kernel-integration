/// Test B1: DVFS 상태 전이
pub fn test_b1_dvfs_state_transitions() -> bool {
    // 상태 확인
    if !validate_dvfs_state(DVFSState::Min200MHz) {
        return false;
    }
    if !validate_dvfs_state(DVFSState::Max2GHz) {
        return false;
    }

    // 주파수 값 확인
    if DVFSState::Min200MHz.to_mhz() != 200 {
        return false;
    }
    if DVFSState::Max2GHz.to_mhz() != 2000 {
        return false;
    }

    // 전압 값 확인
    if (DVFSState::Min200MHz.to_voltage() - 0.8).abs() > 1e-6 {
        return false;
    }
    if (DVFSState::Max2GHz.to_voltage() - 1.2).abs() > 1e-6 {
        return false;
    }

    // 전력 값 확인
    if DVFSState::Min200MHz.to_power_mw() != 50 {
        return false;
    }
    if DVFSState::Max2GHz.to_power_mw() != 700 {
        return false;
    }

    // next_state 확인
    let next = DVFSState::Min200MHz.next_state();
    if next as u32 != DVFSState::Low500MHz as u32 {
        return false;
    }

    // prev_state 확인
    let prev = DVFSState::Max2GHz.prev_state();
    if prev as u32 != DVFSState::High1_5GHz as u32 {
        return false;
    }

    true
}

/// Test B2: 워크로드 프로필 생성 및 검증
pub fn test_b2_workload_profile_creation() -> bool {
    let profile = WorkloadProfile::new(2.5, 0.1, 0.05, 0.6, 0.7);

    if !profile.validate() {
        return false;
    }

    if !validate_workload_profile(&profile) {
        return false;
    }

    // 경계값 테스트
    let profile_min = WorkloadProfile::new(0.5, 0.0, 0.0, 0.0, 0.0);
    if !profile_min.validate() {
        return false;
    }

    let profile_max = WorkloadProfile::new(4.0, 1.0, 1.0, 1.0, 1.0);
    if !profile_max.validate() {
        return false;
    }

    true
}

/// Test B3: DVFS 예측 정확도 (< 5% 오차)
pub fn test_b3_dvfs_prediction_accuracy() -> bool {
    let mut predictor = DVFSPredictor::new();

    let profile = WorkloadProfile::new(1.5, 0.15, 0.1, 0.5, 0.6);
    let predicted = predictor.predict_optimal_freq(&profile);

    if !validate_dvfs_state(predicted) {
        return false;
    }

    // 예측 오차 측정: 실제 상태는 Mid1GHz라고 가정
    let actual = DVFSState::Mid1GHz;
    let error = predictor.measure_prediction_error(actual);

    // 오차 < 5% 검증
    if !validate_prediction_error(error) {
        return false;
    }

    // 통계 확인
    let (predictions, _, accuracy, _) = predictor.stats();
    if predictions == 0 {
        return false;
    }

    true
}

/// Test B4: 온도 상태 검증
pub fn test_b4_thermal_state_validation() -> bool {
    let state = ThermalState::new(65.0, 25.0, 500);

    if !state.validate() {
        return false;
    }

    if !validate_thermal_state(&state) {
        return false;
    }

    // 경고 상태 확인
    let warning_state = ThermalState::new(80.0, 25.0, 500);
    if !warning_state.is_warning() {
        return false;
    }

    // 비상 상태 확인
    let critical_state = ThermalState::new(90.0, 25.0, 500);
    if !critical_state.is_critical() {
        return false;
    }

    // 열 마진 계산
    let headroom = state.thermal_headroom(100.0);
    if headroom <= 0.0 || headroom > 1.0 {
        return false;
    }

    true
}

/// Test B5: 온도 1초 예측 (오차 < 2°C)
pub fn test_b5_thermal_prediction_accuracy() -> bool {
    let mut manager = ThermalManager::new();

    // 샘플 추가 (온도 기록)
    let state1 = ThermalState::new(60.0, 25.0, 500);
    manager.add_sample(state1);

    let state2 = ThermalState::new(62.0, 25.0, 500);
    manager.add_sample(state2);

    // 1초 후 온도 예측
    let predicted = manager.predict_temp_1sec(&state2);

    // 예상: 62.0°C 근처 (±2°C 이내)
    if predicted < 60.0 || predicted > 100.0 {
        return false;
    }

    // 예측 오차 측정 (실제 온도는 63.0°C라고 가정)
    let actual = 63.0;
    let error = manager.measure_prediction_error(predicted, actual);

    // 오차 < 2°C 검증
    if !validate_temp_prediction(predicted, actual) {
        return false;
    }

    true
}

/// Test B6: 자동 쓰로틀링 반응
pub fn test_b6_auto_throttle_response() -> bool {
    let mut manager = ThermalManager::new();

    // 일반 온도
    let normal_state = ThermalState::new(65.0, 25.0, 500);
    let throttle_normal = manager.auto_throttle(&normal_state);
    if !validate_throttle_response(throttle_normal) {
        return false;
    }
    if throttle_normal != 0 {
        return false;
    }

    // 주의 온도 (70°C)
    let caution_state = ThermalState::new(72.0, 25.0, 500);
    let throttle_caution = manager.auto_throttle(&caution_state);
    if throttle_caution != 1 {  // 10% 쓰로틀
        return false;
    }

    // 경고 온도 (75-80°C)
    let warning_state = ThermalState::new(78.0, 25.0, 500);
    let throttle_warning = manager.auto_throttle(&warning_state);
    if throttle_warning != 2 {  // 25% 쓰로틀
        return false;
    }

    // 비상 온도 (85°C)
    let critical_state = ThermalState::new(88.0, 25.0, 500);
    let throttle_critical = manager.auto_throttle(&critical_state);
    if throttle_critical != 3 {  // 50% 쓰로틀
        return false;
    }

    true
}

/// Test B7: 열 정책 적용
pub fn test_b7_thermal_policy_application() -> bool {
    let policy = ThermalPolicy::default();
    let mut manager = ThermalManager::new();
    let mut state = ThermalState::new(70.0, 25.0, 500);

    let can_continue = policy.apply(&mut manager, &mut state);
    if !can_continue || state.die_temp_celsius >= policy.shutdown_temp {
        return false;
    }

    // 고온 상태에서 정책 적용
    let mut critical_state = ThermalState::new(105.0, 25.0, 500);
    let can_continue_critical = policy.apply(&mut manager, &mut critical_state);

    // Shutdown 온도 초과 시 false 반환
    if can_continue_critical == true && critical_state.die_temp_celsius >= policy.shutdown_temp {
        return false;
    }

    true
}

/// Test B8: DVFS 제어기 상태 적용
pub fn test_b8_dvfs_controller_application() -> bool {
    let mut controller = DVFSController::new();

    let state = DVFSState::Mid1GHz;
    if !controller.apply_dvfs(state) {
        return false;
    }

    // 상태 확인
    if controller.last_applied_state as u32 != state as u32 {
        return false;
    }

    // 주파수 변경 횟수 증가 확인
    if controller.frequency_changes_per_sec != 1 {
        return false;
    }

    true
}

/// Test B9: 워크로드 기반 자동 스케일링
pub fn test_b9_workload_based_scaling() -> bool {
    let mut controller = DVFSController::new();

    // 고 IPC 워크로드
    let high_workload = WorkloadProfile::new(3.5, 0.05, 0.02, 0.8, 0.9);
    let state = controller.auto_scale(&high_workload);

    if !validate_dvfs_state(state) {
        return false;
    }

    // 저 IPC 워크로드
    let low_workload = WorkloadProfile::new(0.8, 0.3, 0.15, 0.2, 0.3);
    let state_low = controller.auto_scale(&low_workload);

    if !validate_dvfs_state(state_low) {
        return false;
    }

    true
}

/// Test B10: 주파수 변경률 제한
pub fn test_b10_frequency_change_rate_limiting() -> bool {
    let mut controller = DVFSController::new();

    // 최대 변경 횟수만큼 적용
    for _ in 0..controller.max_freq_changes_allowed {
        let _ = controller.apply_dvfs(DVFSState::Mid1GHz);
    }

    // 제한 도달 후 추가 변경 시도
    if controller.apply_dvfs(DVFSState::High1_5GHz) {
        return false;  // 실패해야 함
    }

    // 변경률 검증
    if !validate_frequency_change_rate(controller.frequency_changes_per_sec) {
        return false;
    }

    // 버짓 검증
    if !validate_thermal_budget(500) {
        return false;
    }

    true
}

// ============================================================================
// Group C: Threat Engine Tests (C1-C10)
// ============================================================================

/// Test C1: 위협 타입 검증
pub fn test_c1_threat_type_validation() -> bool {
    if !validate_threat_type(ThreatType::None) {
        return false;
    }
    if !validate_threat_type(ThreatType::PrivilegeEscalation) {
        return false;
    }
    if !validate_threat_type(ThreatType::DirtyPipe) {
        return false;
    }

    // to_u32 / from_u32 라운드트립
    let threat = ThreatType::MemoryExploit;
    let val = threat.to_u32();
    if let Some(restored) = ThreatType::from_u32(val) {
        if restored as u32 != threat as u32 {
            return false;
        }
    } else {
        return false;
    }

    true
}

/// Test C2: 시스콜 특성 생성 및 검증
pub fn test_c2_syscall_features_creation() -> bool {
    let mut features = SyscallFeatures::new();
    features.syscall_id = 59.0;  // execve
    features.privilege_level = 0.5;
    features.anomaly_score = 0.3;

    if !features.validate() {
        return false;
    }

    // 특성 벡터로 변환
    let feature_vec = features.to_feature_vector();
    if feature_vec.len() != 16 {
        return false;
    }

    // 모든 값이 0.0~1.0 범위인지 확인
    for &val in &feature_vec {
        if val < 0.0 || val > 1.0 {
            return false;
        }
    }

    true
}

/// Test C3: 실시간 위협 탐지 (< 10µs)
pub fn test_c3_realtime_threat_detection() -> bool {
    let mut predictor = RealtimeThreatPredictor::new();

    let mut features = SyscallFeatures::new();
    features.syscall_id = 59.0;  // execve (권한 상승 시뮝)
    features.privilege_level = 0.9;
    features.suspicious_args = 1.0;
    features.anomaly_score = 0.8;

    let (threat_type, threat_score) = predictor.predict_threat(&features);

    if !validate_threat_type(threat_type) {
        return false;
    }

    if !validate_threat_score(threat_score) {
        return false;
    }

    // 총 예측 증가 확인
    let (total, _, _, _, _, _) = predictor.stats();
    if total != 1 {
        return false;
    }

    true
}

/// Test C4: 위협 탐지 임계값
pub fn test_c4_threat_detection_threshold() -> bool {
    let mut predictor = RealtimeThreatPredictor::new();

    let mut features = SyscallFeatures::new();
    features.syscall_id = 59.0;
    features.anomaly_score = 0.95;  // 높은 이상 점수

    // 임계값 0.7로 탐지
    let threat = predictor.predict_threat_with_threshold(&features, 0.7);

    if threat as u32 == ThreatType::None as u32 {
        // 낮은 임계값에서는 위협으로 간주해야 함
        // (예측된 점수가 0.7 이상인 경우)
        // 이 부분은 모델의 예측에 따라 달라짐
    }

    true
}

/// Test C5: 예측 정확도 측정
pub fn test_c5_prediction_accuracy_measurement() -> bool {
    let mut predictor = RealtimeThreatPredictor::new();

    // 10개 예측, 8개 정확
    for i in 0..10 {
        let predicted = if i < 8 {
            ThreatType::PrivilegeEscalation
        } else {
            ThreatType::None
        };
        let actual = ThreatType::PrivilegeEscalation;

        predictor.measure_accuracy(predicted, actual);
    }

    let accuracy = predictor.accuracy();
    if accuracy <= 0.0 || accuracy > 100.0 {
        return false;
    }

    // 오탐지율 계산
    let fpr = predictor.false_positive_rate();
    if fpr < 0.0 || fpr > 100.0 {
        return false;
    }

    // 검출율 계산
    let tpr = predictor.detection_rate();
    if tpr < 0.0 || tpr > 100.0 {
        return false;
    }

    true
}

/// Test C6: 링 버퍼 기본 연산
pub fn test_c6_ring_buffer_basic_operations() -> bool {
    let mut ring = ZeroCopyRingBuffer::new();

    if !ring.is_empty() {
        return false;
    }

    // 이벤트 추가
    let mut features = SyscallFeatures::new();
    features.syscall_id = 1.0;
    let event = RingBufferEvent::new(1, 1000, features);

    if !ring.push_event(event) {
        return false;
    }

    if ring.is_empty() {
        return false;
    }

    // 이벤트 제거
    if let Some(popped) = ring.pop_event() {
        if popped.event_id != 1 {
            return false;
        }
    } else {
        return false;
    }

    if !ring.is_empty() {
        return false;
    }

    true
}

/// Test C7: 링 버퍼 오버플로우 감지
pub fn test_c7_ring_buffer_overflow() -> bool {
    let mut ring = ZeroCopyRingBuffer::new();
    let mut features = SyscallFeatures::new();

    // 용량까지 채우기 (4095개까지 가능, 4096번째는 오버플로우)
    for i in 0..4095 {
        let event = RingBufferEvent::new(i, i as u64 * 1000, features.clone());
        if !ring.push_event(event) {
            return false;
        }
    }

    // 다음 추가는 실패해야 함 (읽기 인덱스 덮을 예정)
    let event = RingBufferEvent::new(4095, 4095000, features);
    if ring.push_event(event) {
        return false;  // 오버플로우 감지 실패
    }

    // 오버플로우 카운트 증가 확인
    if ring.buffer_overflow_count == 0 {
        return false;
    }

    true
}

/// Test C8: 제로카피 파이프라인 배치 처리
pub fn test_c8_zero_copy_pipeline_batching() -> bool {
    let mut pipeline = ZeroCopyPipeline::with_batch_size(32);
    let mut features = SyscallFeatures::new();

    // 100개 이벤트 추가
    for i in 0..100 {
        let event = RingBufferEvent::new(i as u64, i as u64 * 1000, features.clone());
        let _ = pipeline.add_event(event);
    }

    // 배치 처리
    let batch1 = pipeline.process_batch();
    if batch1.len() != 32 {
        return false;
    }

    let batch2 = pipeline.process_batch();
    if batch2.len() != 32 {
        return false;
    }

    let batch3 = pipeline.process_batch();
    if batch3.len() != 32 {
        return false;
    }

    // 4번째 배치는 4개만 남음
    let batch4 = pipeline.process_batch();
    if batch4.len() != 4 {
        return false;
    }

    true
}

/// Test C9: 파이프라인 처리량 및 손실률
pub fn test_c9_pipeline_throughput_and_loss() -> bool {
    let mut pipeline = ZeroCopyPipeline::new();
    let mut features = SyscallFeatures::new();

    // 1000개 이벤트 추가
    for i in 0..1000 {
        let event = RingBufferEvent::new(i as u64, i as u64 * 1000, features.clone());
        let _ = pipeline.add_event(event);
    }

    // 모두 처리
    while let Some(_event) = pipeline.ring_buffer.pop_event() {
        // 처리
    }

    let loss_rate = pipeline.loss_rate();
    if !validate_loss_rate(loss_rate) {
        return false;
    }

    // 손실률 = 0%
    if loss_rate != 0.0 {
        return false;
    }

    true
}

/// Test C10: 엔드투엔드 위협 탐지 파이프라인
pub fn test_c10_e2e_threat_detection_pipeline() -> bool {
    let mut predictor = RealtimeThreatPredictor::new();
    let mut pipeline = ZeroCopyPipeline::with_batch_size(16);

    // 100개 시스콜 이벤트 생성
    let mut features = SyscallFeatures::new();
    for i in 0..100 {
        features.syscall_id = (i % 10) as f32 + 1.0;
        features.anomaly_score = ((i % 5) as f32) * 0.2;  // 0.0~0.8
        features.privilege_level = 0.5;

        let event = RingBufferEvent::new(i as u64, i as u64 * 1000, features.clone());
        let _ = pipeline.add_event(event);
    }

    // 배치로 처리하며 위협 탐지
    let mut total_detections = 0u32;
    loop {
        let batch = pipeline.process_batch();
        if batch.is_empty() {
            break;
        }

        for event in batch {
            let (threat_type, _score) = predictor.predict_threat(&event.features);
            if threat_type as u32 > 0 {
                total_detections += 1;
            }
        }
    }

    // 위협 탐지 통계 확인
    let (predictions, _, _, _, _, accuracy) = predictor.stats();
    if predictions != 100 {
        return false;
    }

    if accuracy < 0.0 || accuracy > 100.0 {
        return false;
    }

    true
}

// ============================================================================
// Group D: Distributed Optimizer Tests (D1-D10)
// ============================================================================

/// Test D1: 코어 상태 검증
pub fn test_d1_core_state_validation() -> bool {
    if !validate_core_state(CoreState::Idle) {
        return false;
    }
    if !validate_core_state(CoreState::Synchronized) {
        return false;
    }

    // 상태 변환 확인
    let state = CoreState::Working;
    if state as u32 != 1 {
        return false;
    }

    true
}

/// Test D2: 합의 상태 초기화
pub fn test_d2_consensus_state_initialization() -> bool {
    let consensus = ConsensusState::new(0, 8);

    if !consensus.is_valid() {
        return false;
    }

    if consensus.core_id != 0 {
        return false;
    }

    if consensus.quorum_size() != 5 {  // (8/2)+1 = 5
        return false;
    }

    true
}

/// Test D3: 리더 선출
pub fn test_d3_leader_election() -> bool {
    let mut consensus = MulticoreConsensus::new(8);

    let leader = consensus.elect_leader();

    if !validate_leader_election(leader, 8) {
        return false;
    }

    if consensus.leader_id != leader {
        return false;
    }

    true
}

/// Test D4: 결정 브로드캐스트
pub fn test_d4_decision_broadcast() -> bool {
    let mut consensus = MulticoreConsensus::new(8);
    consensus.elect_leader();

    let decision = OptimizationDecision::new(0, 0.75, 0);
    if !validate_decision(&decision) {
        return false;
    }

    // 리더로 설정하여 브로드캐스트 활성화
    consensus.is_leader = true;
    let result = consensus.broadcast_decision(decision);

    // 브로드캐스트 결과 확인
    if !result {
        return false;
    }

    true
}

/// Test D5: 합의 레이턴시 측정 (< 1ms)
pub fn test_d5_consensus_latency_measurement() -> bool {
    let mut consensus = MulticoreConsensus::new(8);

    // 500µs 레이턴시 (< 1ms)
    let latency_ns = 500000u64;
    if !consensus.measure_consensus_latency(latency_ns) {
        return false;
    }

    if !validate_consensus_latency(latency_ns) {
        return false;
    }

    // 평균 레이턴시 확인
    let (_, _, _, _, _, avg_lat, _) = consensus.stats();
    if avg_lat != latency_ns {
        return false;
    }

    true
}

/// Test D6: 합의 동기화
pub fn test_d6_consensus_synchronization() -> bool {
    let mut consensus = MulticoreConsensus::new(8);
    consensus.elect_leader();

    if !consensus.synchronize_cores() {
        return false;
    }

    // 모든 코어가 같은 term을 가져야 함
    let leader_term = consensus.consensus_state[consensus.leader_id as usize].term;
    for state in &consensus.consensus_state {
        if state.term != leader_term {
            return false;
        }
    }

    true
}

/// Test D7: 성능 메트릭 생성
pub fn test_d7_performance_metrics_creation() -> bool {
    let mut metrics = PerformanceMetrics::new();
    metrics.throughput = 5000.0;
    metrics.latency_us = 10.0;
    metrics.power_mw = 250.0;
    metrics.cpu_utilization = 0.75;
    metrics.cache_hit_rate = 0.85;

    if !validate_performance_metrics(&metrics) {
        return false;
    }

    // 특성 벡터로 변환
    let features = metrics.to_feature_vector();
    if features.len() != 8 {
        return false;
    }

    true
}

/// Test D8: 자율적 최적화 결정
pub fn test_d8_autonomous_optimization_decision() -> bool {
    let mut optimizer = SelfOptimizer::new();

    let mut metrics = PerformanceMetrics::new();
    metrics.throughput = 8000.0;
    metrics.latency_us = 5.0;
    metrics.power_mw = 350.0;
    metrics.cpu_utilization = 0.9;
    metrics.cache_hit_rate = 0.88;

    optimizer.update_metrics(metrics);

    let decision = optimizer.make_autonomous_decision();

    if !validate_decision(&decision) {
        return false;
    }

    if !validate_decision_confidence(decision.confidence) {
        return false;
    }

    // 자율 결정 카운터 증가 확인
    if optimizer.autonomous_decisions != 1 {
        return false;
    }

    true
}

/// Test D9: 성능 개선 추적 (> 10%)
pub fn test_d9_performance_improvement_tracking() -> bool {
    let mut optimizer = SelfOptimizer::new();

    // 이전 메트릭 설정
    let mut prev_metrics = PerformanceMetrics::new();
    prev_metrics.latency_us = 20.0;
    prev_metrics.power_mw = 400.0;
    prev_metrics.throughput = 5000.0;

    optimizer.update_metrics(prev_metrics);

    // 최적화 적용 (향상된 메트릭)
    let mut curr_metrics = PerformanceMetrics::new();
    curr_metrics.latency_us = 15.0;  // 25% 개선
    curr_metrics.power_mw = 350.0;   // 12.5% 개선
    curr_metrics.throughput = 7000.0; // 40% 개선

    optimizer.update_metrics(curr_metrics);

    // 개선률 계산
    let improvement = optimizer.calculate_improvement();

    // 개선이 나타났는지 확인 (양수여야 함)
    if improvement <= 0.0 {
        return false;
    }

    // 최적화 적용
    optimizer.apply_optimization(true);

    // 평균 개선률 > 10% 검증
    if !validate_improvement(optimizer.avg_improvement_pct) {
        return false;
    }

    true
}

/// Test D10: E2E 분산 최적화 파이프라인
pub fn test_d10_e2e_distributed_optimization() -> bool {
    let mut consensus = MulticoreConsensus::new(4);
    let mut optimizer = SelfOptimizer::new();

    consensus.elect_leader();

    // 10 사이클 실행
    for i in 0..10 {
        // 성능 메트릭 업데이트
        let mut metrics = PerformanceMetrics::new();
        metrics.throughput = 4000.0 + (i as f32 * 100.0);
        metrics.latency_us = 15.0 - (i as f32 * 0.5);
        metrics.power_mw = 300.0 - (i as f32 * 5.0);
        metrics.cpu_utilization = 0.6 + (i as f32 * 0.03);

        optimizer.update_metrics(metrics);

        // 자율 결정
        let decision = optimizer.make_autonomous_decision();

        // 합의 브로드캐스트
        if consensus.is_leader {
            let _ = consensus.broadcast_decision(decision);
        }

        // 최적화 적용
        optimizer.apply_optimization(true);
    }

    // 통계 확인
    let (cycles, auto_decisions, successes, _, _, efficiency) = optimizer.stats();

    if cycles != 10 {
        return false;
    }

    if auto_decisions != 10 {
        return false;
    }

    if successes < 9 {
        return false;
    }

    // 효율성 > 90%
    if efficiency < 90.0 {
        return false;
    }

    // 자율성 확인
    if !optimizer.is_fully_autonomous() {
        return false;
    }

    true
}

// ============================================================================
// Test Runner
// ============================================================================

pub struct Phase8TestRunner {
    pub group_a_passed: u32,
    pub group_a_total: u32,
    pub group_b_passed: u32,
    pub group_b_total: u32,
    pub group_c_passed: u32,
    pub group_c_total: u32,
    pub group_d_passed: u32,
    pub group_d_total: u32,
    pub total_passed: u32,
    pub total_tests: u32,
}

impl Phase8TestRunner {
    pub fn new() -> Self {
        Phase8TestRunner {
            group_a_passed: 0,
            group_a_total: 10,
            group_b_passed: 0,
            group_b_total: 10,
            group_c_passed: 0,
            group_c_total: 10,
            group_d_passed: 0,
            group_d_total: 10,
            total_passed: 0,
            total_tests: 40,
        }
    }

    pub fn run_group_a(&mut self) -> bool {
        let mut passed = 0u32;

        if test_a1_simd_vec4_operations() { passed += 1; }
        if test_a2_simd_relu_activation() { passed += 1; }
        if test_a3_simd_matrix_vector_multiply() { passed += 1; }
        if test_a4_simd_matrix_transpose() { passed += 1; }
        if test_a5_l0_inference_speed() { passed += 1; }
        if test_a6_l0_zero_copy_memory() { passed += 1; }
        if test_a7_l0_weight_update() { passed += 1; }
        if test_a8_l0_batch_inference() { passed += 1; }
        if test_a9_l0_numerical_stability() { passed += 1; }
        if test_a10_l0_accuracy_tracking() { passed += 1; }

        self.group_a_passed = passed;
        self.total_passed += passed;

        passed == self.group_a_total
    }

    pub fn run_group_b(&mut self) -> bool {
        let mut passed = 0u32;

        if test_b1_dvfs_state_transitions() { passed += 1; }
        if test_b2_workload_profile_creation() { passed += 1; }
        if test_b3_dvfs_prediction_accuracy() { passed += 1; }
        if test_b4_thermal_state_validation() { passed += 1; }
        if test_b5_thermal_prediction_accuracy() { passed += 1; }
        if test_b6_auto_throttle_response() { passed += 1; }
        if test_b7_thermal_policy_application() { passed += 1; }
        if test_b8_dvfs_controller_application() { passed += 1; }
        if test_b9_workload_based_scaling() { passed += 1; }
        if test_b10_frequency_change_rate_limiting() { passed += 1; }

        self.group_b_passed = passed;
        self.total_passed += passed;

        passed == self.group_b_total
    }

    pub fn run_group_c(&mut self) -> bool {
        let mut passed = 0u32;

        if test_c1_threat_type_validation() { passed += 1; }
        if test_c2_syscall_features_creation() { passed += 1; }
        if test_c3_realtime_threat_detection() { passed += 1; }
        if test_c4_threat_detection_threshold() { passed += 1; }
        if test_c5_prediction_accuracy_measurement() { passed += 1; }
        if test_c6_ring_buffer_basic_operations() { passed += 1; }
        if test_c7_ring_buffer_overflow() { passed += 1; }
        if test_c8_zero_copy_pipeline_batching() { passed += 1; }
        if test_c9_pipeline_throughput_and_loss() { passed += 1; }
        if test_c10_e2e_threat_detection_pipeline() { passed += 1; }

        self.group_c_passed = passed;
        self.total_passed += passed;

        passed == self.group_c_total
    }

    pub fn run_group_d(&mut self) -> bool {
        let mut passed = 0u32;

        if test_d1_core_state_validation() { passed += 1; }
        if test_d2_consensus_state_initialization() { passed += 1; }
        if test_d3_leader_election() { passed += 1; }
        if test_d4_decision_broadcast() { passed += 1; }
        if test_d5_consensus_latency_measurement() { passed += 1; }
        if test_d6_consensus_synchronization() { passed += 1; }
        if test_d7_performance_metrics_creation() { passed += 1; }
        if test_d8_autonomous_optimization_decision() { passed += 1; }
        if test_d9_performance_improvement_tracking() { passed += 1; }
        if test_d10_e2e_distributed_optimization() { passed += 1; }

        self.group_d_passed = passed;
        self.total_passed += passed;

        passed == self.group_d_total
    }

    pub fn print_results(&self) {
        println!("\n╔════════════════════════════════════════════════════════════╗");
        println!("║     Phase 8 Neural-Kernel Integration Tests: COMPLETE     ║");
        println!("╚════════════════════════════════════════════════════════════╝");
        println!("Group A (L0 Engine): {}/{}", self.group_a_passed, self.group_a_total);
        println!("Group B (Hardware Optimizer): {}/{}", self.group_b_passed, self.group_b_total);
        println!("Group C (Threat Engine): {}/{}", self.group_c_passed, self.group_c_total);
        println!("Group D (Distributed Optimizer): {}/{}", self.group_d_passed, self.group_d_total);
        println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
        println!("TOTAL: {}/{} ({}%)", self.total_passed, self.total_tests, (self.total_passed * 100) / self.total_tests);

        if self.group_a_passed == self.group_a_total {
            println!("✅ Group A PASSED (10/10) - L0 Engine");
        } else {
            println!("❌ Group A FAILED ({}/10) - L0 Engine", self.group_a_passed);
        }

        if self.group_b_passed == self.group_b_total {
            println!("✅ Group B PASSED (10/10) - Hardware Optimizer");
        } else {
            println!("❌ Group B FAILED ({}/10) - Hardware Optimizer", self.group_b_passed);
        }

        if self.group_c_passed == self.group_c_total {
            println!("✅ Group C PASSED (10/10) - Threat Engine");
        } else {
            println!("❌ Group C FAILED ({}/10) - Threat Engine", self.group_c_passed);
        }

        if self.group_d_passed == self.group_d_total {
            println!("✅ Group D PASSED (10/10) - Distributed Optimizer");
        } else {
            println!("❌ Group D FAILED ({}/10) - Distributed Optimizer", self.group_d_passed);
        }
    }
}

pub fn run_phase8_tests() -> bool {
    let mut runner = Phase8TestRunner::new();
    let group_a = runner.run_group_a();
    let group_b = runner.run_group_b();
    let group_c = runner.run_group_c();
    let group_d = runner.run_group_d();
    runner.print_results();
    group_a && group_b && group_c && group_d && (runner.total_passed == 40)
}
